---
const { size = "medium" } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;

const sizes = {
  small: { height: "40px", width: "160px", fontSize: "0.9rem", imgSize: "30px" },
  medium: { height: "60px", width: "240px", fontSize: "1.2rem", imgSize: "45px" },
  large: { height: "80px", width: "320px", fontSize: "1.6rem", imgSize: "60px" }
};

const currentSize = sizes[size] || sizes.medium;
---

<div class="logo-wrapper" style={`height: ${currentSize.height}; width: ${currentSize.width};`}>
  <div class="logo-mark">
    <img src={`${baseUrl}/images/IMG-20260228-WA0001.jpg`} alt="Earthen Touch Icon" />
  </div>
  <span class="logo-text" style={`font-size: ${currentSize.fontSize};`}>EARTHEN TOUCH</span>
</div>

<style>
  .logo-wrapper {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
    color: var(--text-color);
  }

  .logo-mark {
    flex-shrink: 0;
    width: 45px; /* Default size, will be overridden by inline style if needed but for simplicity we use CSS */
    height: 45px;
    border-radius: 50%;
    overflow: hidden;
    border: 1px solid var(--accent-color);
  }

  .logo-mark img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .logo-text {
    font-family: var(--serif);
    font-weight: 500;
    letter-spacing: 0.2rem;
    white-space: nowrap;
    text-transform: uppercase;
  }

  /* Responsive adjustments based on container */
  @media (max-width: 640px) {
    .logo-wrapper {
      width: auto !important;
      gap: 0.5rem;
    }
    .logo-text {
      font-size: 0.9rem !important;
    }
    .logo-mark {
      width: 30px;
      height: 30px;
    }
  }
</style>
