---
const { title, price, image, category, inventoryStatus, slug } = Astro.props;
---

<a href={`${import.meta.env.BASE_URL}/products/${slug}`} class="product-card">
	<div class="image-container">
		<img src={image} alt={title} />
		{inventoryStatus === 'sold_out' && <span class="badge">Sold Out</span>}
	</div>
	<div class="product-info">
		<p class="category">{category}</p>
		<h3>{title}</h3>
		<p class="price">₹{price}</p>
	</div>
</a>

<style>
	.product-card {
		text-decoration: none;
		color: inherit;
		display: block;
		transition: transform 0.3s ease;
	}
	.product-card:hover {
		transform: translateY(-5px);
	}
	.image-container {
		position: relative;
		aspect-ratio: 4/5;
		overflow: hidden;
		background: #f0f0f0;
	}
	img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
	}
	.product-card:hover img {
		transform: scale(1.05);
	}
	.badge {
		position: absolute;
		top: 1rem;
		left: 1rem;
		background: rgba(255, 255, 255, 0.9);
		padding: 0.3rem 0.8rem;
		font-size: 0.6rem;
		text-transform: uppercase;
		letter-spacing: 0.1rem;
	}
	.product-info {
		padding: 1rem 0;
	}
	.category {
		font-size: 0.7rem;
		text-transform: uppercase;
		letter-spacing: 0.1rem;
		color: var(--accent-color);
		margin-bottom: 0.5rem;
	}
	h3 {
		margin: 0;
		font-size: 1.1rem;
		font-family: var(--serif);
	}
	.price {
		margin-top: 0.5rem;
		font-weight: 300;
		font-size: 0.9rem;
	}
</style>
