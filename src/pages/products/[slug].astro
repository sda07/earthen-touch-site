---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { Content } = await product.render();

// Custom WhatsApp message
const whatsappMessage = encodeURIComponent(`Hi! I'm interested in the ${product.data.title}. Is it available?`);
const whatsappUrl = `https://wa.me/910000000000?text=${whatsappMessage}`;
---

<Layout title={`${product.data.title} | Earthen Touch`}>
	<div class="product-detail">
		<div class="image-gallery">
			<img src={product.data.image} alt={product.data.title} />
		</div>
		<div class="product-info">
			<p class="category">{product.data.category}</p>
			<h1>{product.data.title}</h1>
			<p class="price">₹{product.data.price}</p>
			
			<div class="description">
				<p>{product.data.description}</p>
				<Content />
			</div>

			{product.data.inventoryStatus === 'live' ? (
				<a href={whatsappUrl} class="buy-btn" target="_blank">Inquire on WhatsApp</a>
			) : (
				<div class="sold-out-msg">This item is currently sold out.</div>
			)}

			<div class="shipping-info">
				<p>• Worldwide shipping available</p>
				<p>• Carefully packaged in sustainable materials</p>
				<p>• Each piece is handmade and unique</p>
			</div>
		</div>
	</div>

	<style>
		.product-detail {
			display: grid;
			grid-template-columns: 1.2fr 1fr;
			gap: 4rem;
			padding: 4rem 0;
			align-items: start;
		}
		@media (max-width: 768px) {
			.product-detail {
				grid-template-columns: 1fr;
				gap: 2rem;
			}
		}
		.image-gallery img {
			width: 100%;
			aspect-ratio: 4/5;
			object-fit: cover;
			background: #f0f0f0;
		}
		.product-info {
			position: sticky;
			top: 8rem;
		}
		.category {
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.15rem;
			color: var(--accent-color);
			margin-bottom: 1rem;
		}
		h1 {
			font-size: 2.5rem;
			margin: 0 0 1rem;
		}
		.price {
			font-size: 1.5rem;
			font-weight: 300;
			margin-bottom: 2rem;
		}
		.description {
			margin-bottom: 3rem;
			font-size: 1rem;
			color: #555;
		}
		.buy-btn {
			display: block;
			width: 100%;
			padding: 1.2rem;
			background: var(--text-color);
			color: white;
			text-align: center;
			text-decoration: none;
			text-transform: uppercase;
			letter-spacing: 0.2rem;
			font-size: 0.8rem;
			transition: background 0.3s ease;
		}
		.buy-btn:hover {
			background: var(--accent-color);
		}
		.sold-out-msg {
			padding: 1.2rem;
			background: #f5f5f5;
			color: #999;
			text-align: center;
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.1rem;
		}
		.shipping-info {
			margin-top: 3rem;
			padding-top: 2rem;
			border-top: 1px solid #eee;
			font-size: 0.8rem;
			color: #888;
		}
		.shipping-info p {
			margin: 0.5rem 0;
		}
	</style>
</Layout>
