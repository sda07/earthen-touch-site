---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ProductCard from '../components/ProductCard.astro';

// Inventory logic: Filter out 'discontinued' items
const allProducts = await getCollection('products', ({ data }) => {
	return data.inventoryStatus !== 'discontinued';
});

const featuredProducts = allProducts.filter(p => p.data.featured);

const baseUrl = import.meta.env.BASE_URL;
---

<Layout title="Earthen Touch | Handmade Pottery & Jewellery">
	<!-- Hero Section -->
	<section class="hero">
		<div class="hero-container">
			<div class="hero-content">
				<span class="eyebrow">Handcrafted with Intention</span>
				<h1>Artisan Crafts for Modern Living</h1>
				<p>Hand-thrown pottery and curated jewellery, crafted with soul in our small studio.</p>
				<div class="hero-actions">
					<a href={`${baseUrl}/products`} class="btn btn-primary">Shop Collection</a>
					<a href={`${baseUrl}/about`} class="btn btn-secondary">Our Story</a>
				</div>
			</div>
			<div class="hero-gallery">
				<div class="hero-image main-image">
					<img src={`${baseUrl}/images/IMG-20260228-WA0001.jpg`} alt="Handcrafted pottery work" />
				</div>
				<div class="hero-image secondary-image">
					<img src={`${baseUrl}/images/IMG-20260228-WA0003.jpg`} alt="Detail of artisan craft" />
				</div>
			</div>
		</div>
	</section>

	<!-- Highlights Section -->
	<section class="highlights">
		<div class="highlights-grid">
			<div class="highlight-item">
				<div class="image-wrapper">
					<img src={`${baseUrl}/images/IMG-20260228-WA0004.jpg`} alt="Pottery collection" />
				</div>
				<div class="highlight-text">
					<h3>Earth-born Materials</h3>
					<p>Sourced from local clay and natural pigments, each piece tells a story of the land.</p>
				</div>
			</div>
			<div class="highlight-item reverse">
				<div class="image-wrapper">
					<img src={`${baseUrl}/images/IMG-20260228-WA0006.jpg`} alt="Jewellery details" />
				</div>
				<div class="highlight-text">
					<h3>Timeless Design</h3>
					<p>Jewellery that bridges the gap between ancient techniques and modern aesthetics.</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Featured Collection -->
	<section class="featured">
		<div class="section-header">
			<div class="header-content">
				<h2>Featured Collection</h2>
				<p>A curated selection of our most loved pieces.</p>
			</div>
			<a href={`${baseUrl}/products`} class="view-all">View All</a>
		</div>
		<div class="product-grid">
			{featuredProducts.map(product => (
				<ProductCard 
					title={product.data.title}
					price={product.data.price}
					image={product.data.image}
					category={product.data.category}
					inventoryStatus={product.data.inventoryStatus}
					slug={product.slug}
				/>
			))}
		</div>
	</section>

	<!-- Craftmanship/Process Section -->
	<section class="process">
		<div class="process-container">
			<div class="process-text">
				<h2>The Beauty of Imperfection</h2>
				<p>In a world of mass production, we celebrate the unique variations that only a human hand can create. No two pieces are ever identical, giving each object its own soul and character.</p>
				<ul class="process-list">
					<li>Sustainable Sourcing</li>
					<li>Traditional Hand-throwing</li>
					<li>Small Batch Production</li>
				</ul>
			</div>
			<div class="process-visual">
				<div class="process-image-grid">
					<img src={`${baseUrl}/images/IMG-20260228-WA0007.jpg`} alt="Pottery process 1" />
					<img src={`${baseUrl}/images/IMG-20260228-WA0008.jpg`} alt="Pottery process 2" />
					<img src={`${baseUrl}/images/IMG-20260228-WA0009.jpg`} alt="Pottery process 3" />
					<img src={`${baseUrl}/images/IMG-20260228-WA0011.jpg`} alt="Pottery process 4" />
				</div>
			</div>
		</div>
	</section>

	<!-- Instagram-style Gallery -->
	<section class="gallery-feed">
		<div class="section-header centered">
			<h2>In the Studio</h2>
			<p>Follow our journey and daily inspirations.</p>
		</div>
		<div class="gallery-grid">
			<img src={`${baseUrl}/images/IMG-20260228-WA0012.jpg`} alt="Studio life" />
			<img src={`${baseUrl}/images/IMG-20260228-WA0013.jpg`} alt="Work in progress" />
			<img src={`${baseUrl}/images/IMG-20260228-WA0014.jpg`} alt="Finished pieces" />
			<img src={`${baseUrl}/images/IMG-20260228-WA0015.jpg`} alt="Packaging" />
		</div>
	</section>

	<style>
		/* Hero Styles */
		.hero {
			padding: 4rem 0 6rem;
		}
		.hero-container {
			display: grid;
			grid-template-columns: 1fr 1.2fr;
			align-items: center;
			gap: 4rem;
		}
		.hero-content {
			max-width: 500px;
		}
		.eyebrow {
			text-transform: uppercase;
			letter-spacing: 0.2rem;
			font-size: 0.8rem;
			color: var(--accent-color);
			margin-bottom: 1.5rem;
			display: block;
			font-weight: 400;
		}
		.hero-content h1 {
			font-size: clamp(3rem, 6vw, 4.5rem);
			line-height: 1.05;
			margin-bottom: 2rem;
			font-weight: 300;
		}
		.hero-content p {
			font-size: 1.2rem;
			color: #555;
			margin-bottom: 2.5rem;
			font-weight: 300;
		}
		.hero-actions {
			display: flex;
			gap: 1.5rem;
		}
		.btn {
			padding: 1rem 2rem;
			text-decoration: none;
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.15rem;
			transition: all 0.3s ease;
			display: inline-block;
		}
		.btn-primary {
			background: var(--text-color);
			color: white;
		}
		.btn-primary:hover {
			background: var(--accent-color);
		}
		.btn-secondary {
			border: 1px solid var(--text-color);
			color: var(--text-color);
		}
		.btn-secondary:hover {
			background: #f0f0f0;
		}
		.hero-gallery {
			position: relative;
			height: 600px;
		}
		.hero-image {
			position: absolute;
			overflow: hidden;
			box-shadow: 0 20px 40px rgba(0,0,0,0.05);
		}
		.main-image {
			width: 80%;
			height: 80%;
			top: 0;
			right: 0;
			z-index: 1;
		}
		.secondary-image {
			width: 50%;
			height: 50%;
			bottom: 0;
			left: 0;
			z-index: 2;
			border: 10px solid var(--bg-color);
		}
		.hero-image img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		/* Highlights Styles */
		.highlights {
			padding: 6rem 0;
			background-color: #f9f9f9;
			margin: 0 -2rem;
			padding: 8rem 4rem;
		}
		.highlights-grid {
			max-width: 1000px;
			margin: 0 auto;
			display: flex;
			flex-direction: column;
			gap: 8rem;
		}
		.highlight-item {
			display: grid;
			grid-template-columns: 1fr 1fr;
			align-items: center;
			gap: 4rem;
		}
		.highlight-item.reverse {
			direction: rtl;
		}
		.highlight-item.reverse .highlight-text {
			direction: ltr;
		}
		.image-wrapper {
			aspect-ratio: 4/5;
			overflow: hidden;
		}
		.image-wrapper img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}
		.highlight-text h3 {
			font-size: 2.2rem;
			margin-bottom: 1.5rem;
		}
		.highlight-text p {
			font-size: 1.1rem;
			color: #666;
			font-weight: 300;
		}

		/* Featured Styles */
		.featured {
			padding: 8rem 0;
		}
		.section-header {
			display: flex;
			justify-content: space-between;
			align-items: flex-end;
			margin-bottom: 4rem;
		}
		.section-header.centered {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
		.header-content h2 {
			font-size: 2.5rem;
			margin-bottom: 1rem;
		}
		.header-content p {
			color: #888;
			font-weight: 300;
		}
		.view-all {
			text-decoration: none;
			color: var(--text-color);
			font-size: 0.8rem;
			text-transform: uppercase;
			letter-spacing: 0.1rem;
			border-bottom: 1px solid var(--text-color);
			padding-bottom: 0.5rem;
		}
		.product-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
			gap: 4rem 2rem;
		}

		/* Process Styles */
		.process {
			padding: 8rem 0;
			border-top: 1px solid #eee;
		}
		.process-container {
			display: grid;
			grid-template-columns: 1fr 1.2fr;
			gap: 5rem;
			align-items: center;
		}
		.process-text h2 {
			font-size: 2.5rem;
			margin-bottom: 2rem;
		}
		.process-text p {
			font-size: 1.1rem;
			color: #555;
			margin-bottom: 2rem;
			font-weight: 300;
		}
		.process-list {
			list-style: none;
			padding: 0;
			margin-top: 3rem;
		}
		.process-list li {
			padding: 1rem 0;
			border-bottom: 1px solid #eee;
			font-size: 0.9rem;
			text-transform: uppercase;
			letter-spacing: 0.1rem;
			color: var(--accent-color);
		}
		.process-image-grid {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 1rem;
		}
		.process-image-grid img {
			width: 100%;
			aspect-ratio: 1;
			object-fit: cover;
		}

		/* Gallery Feed */
		.gallery-feed {
			padding: 8rem 0;
		}
		.gallery-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 1rem;
		}
		.gallery-grid img {
			width: 100%;
			aspect-ratio: 1;
			object-fit: cover;
			transition: opacity 0.3s ease;
		}
		.gallery-grid img:hover {
			opacity: 0.8;
		}

		@media (max-width: 992px) {
			.hero-container, .highlight-item, .process-container {
				grid-template-columns: 1fr;
				gap: 3rem;
			}
			.hero-gallery {
				height: 500px;
			}
			.highlight-item.reverse {
				direction: ltr;
			}
			.gallery-grid {
				grid-template-columns: 1fr 1fr;
			}
		}

		@media (max-width: 640px) {
			.hero-actions {
				flex-direction: column;
			}
			.hero-gallery {
				height: 400px;
			}
			.highlights {
				padding: 4rem 2rem;
			}
		}
	</style>
</Layout>
